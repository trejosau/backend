# Node
TZ=UTC
PORT=3333
HOST=0.0.0.0
NODE_ENV=development

# App
LOG_LEVEL=info
APP_KEY=
APP_URL=http://localhost:3333

# Session
SESSION_DRIVER=cookie

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/railway
DB_SSL=false

# Frontend
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,http://localhost:18080,http://127.0.0.1:18080

# Internal communication
INTERNAL_API_TOKEN=change-me
DEFAULT_MAX_ACCOUNTS_PER_CONTAINER=3

# Accounts nodes bootstrap
SERVICE_NODES_BOOTSTRAP_ENABLED=true
SERVICE_NODES_START=1
SERVICE_NODES_END=20
SERVICE_NODES_CODE_PREFIX=cuentas-
SERVICE_NODES_NAME_PREFIX=Contenedor 
SERVICE_NODES_HOST_PREFIX=cuentas-
SERVICE_NODES_HOST_SUFFIX=.up.railway.app
SERVICE_NODES_PROTOCOL=https
SERVICE_NODES_MAX_ACCOUNTS=3
